# Database Configuration
# Variables con prefijo VITE_ son accesibles desde import.meta.env en el navegador

VITE_DB_MODE=local
# Opciones: "local" (PGlite WASM) | "remote" (PostgreSQL real)

# ═══════════════════════════════════════════════════════════════
# Para VITE_DB_MODE=remote (Producción con PostgreSQL):
# ═══════════════════════════════════════════════════════════════

VITE_DB_HOST=localhost
VITE_DB_PORT=5432
VITE_DB_NAME=modular_workspace
VITE_DB_USER=postgres
VITE_DB_PASSWORD=your_secure_password
VITE_DB_SSL=false

# ═══════════════════════════════════════════════════════════════
# Para VITE_DB_MODE=local (Desarrollo local):
# ═══════════════════════════════════════════════════════════════
# PGlite almacena automáticamente en IndexedDB del navegador
# No requiere credenciales

