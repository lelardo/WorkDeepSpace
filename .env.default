# WorkDeepSpace Environment Configuration

# Database mode: local or remote
VITE_DB_MODE=local

# Only required if VITE_DB_MODE=remote
VITE_DB_HOST=your-postgres-host
VITE_DB_PORT=5432
VITE_DB_NAME=your_database_name
VITE_DB_USER=your_username
VITE_DB_PASSWORD=your_password
VITE_DB_SSL=true

# API server port
API_PORT=3001
