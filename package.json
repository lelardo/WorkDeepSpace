{
  "name": "WorkDeepSpace",
  "description": "workdeepspace",
  "author": "lelardo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "vite",
    "dev:remote": "concurrently \"node server.js\" \"vite\"",
    "electron-dev": "cross-env NODE_ENV=development concurrently \"npm run dev:remote\" \"npx wait-on http://localhost:5173 && npx electron .\"",
    "electron-build": "npm run build && electron-builder",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.1.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "lucide-react": "^0.577.0",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "wait-on": "^7.2.0"
  },
  "main": "electron/main.cjs",
  "homepage": "./",
  "build": {
    "appId": "com.workdeepspace.app",
    "productName": "WorkDeepSpace",
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server.js",
      "public/**/*",
      ".env.default",
      "node_modules/**/*"
    ],
    "win": {
      "icon": "win/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "win/icon.ico",
      "uninstallerIcon": "win/icon.ico"
    }
  }
}
